# Copy this file to .env and fill in the values for your environment.

# ---- Application ----
APP_NAME="VACE - Vulnerability Assessment Consolidation Engine"
ENV=development
DEBUG=false
LOG_LEVEL=INFO

# ---- CORS ----
# JSON array of origins allowed to call the API (pydantic-settings parses
# List[str] env vars as JSON, not comma-separated, despite the field's
# comma-split validator).
CORS_ORIGINS=["http://localhost:3000"]

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql+psycopg://vace_user:vace_password@localhost:5432/vace_db

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Nessus API ----
# Fallback only - once credentials are saved via the Settings page, those
# (encrypted, DB-stored) values take priority over these.
NESSUS_URL=https://localhost:8834
NESSUS_ACCESS_KEY=
NESSUS_SECRET_KEY=
NESSUS_VERIFY_SSL=true

# ---- SonarQube API ----
# Fallback only - same as above.
SONARQUBE_URL=http://localhost:9000
SONARQUBE_TOKEN=
SONARQUBE_VERIFY_SSL=true

# ---- Credential encryption ----
# Encrypts Nessus/SonarQube credentials saved via the Settings page before
# they're stored in the DB. Generate your own for any shared/deployed
# environment - the app.config.py default is dev-only:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=
